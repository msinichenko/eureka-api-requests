meta {
  name: Get keycloack realms
  type: http
  seq: 2
}

get {
  url: https://keycloak-{{folio}}.{{domain}}/admin/realms
  body: text
  auth: bearer
}

headers {
  ~Content-Type: application/x-www-form-urlencoded
}

auth:bearer {
  token: {{master-realm-token}}
}

settings {
  encodeUrl: true
  timeout: 0
}
