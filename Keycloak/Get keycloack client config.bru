meta {
  name: Get keycloack client config
  type: http
  seq: 1
}

get {
  url: https://keycloak-{{folio}}.{{domain}}/admin/realms/{{realm}}/clients/189fa605-2556-43e0-9f25-438e58ee329e
  body: text
  auth: bearer
}

headers {
  ~Content-Type: application/x-www-form-urlencoded
}

auth:bearer {
  token: {{master-realm-token}}
}

settings {
  encodeUrl: true
  timeout: 0
}
