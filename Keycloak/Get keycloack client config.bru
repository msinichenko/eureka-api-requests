meta {
  name: Get keycloack client config
  type: http
  seq: 1
}

get {
  url: https://keycloak-{{folio}}.{{domain}}/admin/realms/{{realm}}/clients/:client_id
  body: text
  auth: bearer
}

params:path {
  client_id: {{some_clientid}}
}

headers {
  ~Content-Type: application/x-www-form-urlencoded
}

auth:bearer {
  token: {{master-realm-token}}
}

settings {
  encodeUrl: true
  timeout: 0
}
