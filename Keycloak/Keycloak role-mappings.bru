meta {
  name: Keycloak role-mappings
  type: http
  seq: 5
}

post {
  url: https://keycloak-{{folio}}.{{domain}}/admin/realms/master/users/:userid/role-mappings/realm
  body: json
  auth: bearer
}

params:path {
  userid: {{some_user_id}}
}

auth:bearer {
  token: {{master-realm-token}}
}

body:json {
  [{"id": "{{some_role_id}}", "name": "admin"}]
}

settings {
  encodeUrl: true
  timeout: 0
}
