meta {
  name: Get keycloack identity providers
  type: http
  seq: 9
}

get {
  url: https://keycloak-{{folio}}.{{domain}}/admin/realms/{{realm}}/identity-provider/instances
  body: none
  auth: bearer
}

headers {
  ~Content-Type: application/x-www-form-urlencoded
}

auth:bearer {
  token: {{master-realm-token}}
}

settings {
  encodeUrl: true
  timeout: 0
}
