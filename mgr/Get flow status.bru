meta {
  name: Get flow status
  type: http
  seq: 8
}

get {
  url: https://kong-{{folio}}.{{domain}}/entitlement-flows/:flow_id?includeStages=true
  body: none
  auth: inherit
}

params:query {
  includeStages: true
}

params:path {
  flow_id: some_id
}

headers {
  ~x-okapi-token: {{master-realm-token}}
}

script:pre-request {
  // const res = await bru.runRequest("auth/get-keycloak-master-realm-folio-backend-admin-client");
}

settings {
  encodeUrl: true
  timeout: 0
}
