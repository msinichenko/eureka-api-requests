meta {
  name: Delete authorities by id
  type: http
  seq: 3
}

delete {
  url: https://kong-{{folio}}.{{domain}}/authority-storage/authorities/:id
  body: none
  auth: none
}

params:path {
  id: 6b0979cd-5463-4177-aad1-f8858677cd85
}

headers {
  x-okapi-tenant: {{realm}}
  x-okapi-token: {{okapi-token}}
  ~x-okapi-token: {{folio-user-token}}
}

script:pre-request {
  const res = await bru.runRequest("auth/get-keycloak-tenant-token");
}

settings {
  encodeUrl: true
  timeout: 0
}
