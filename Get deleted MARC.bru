meta {
  name: Get deleted MARC
  type: http
  seq: 2
}

get {
  url: https://kong-{{folio}}.{{domain}}/authority-storage/authorities?idOnly=true&deleted=true
  body: none
  auth: inherit
}

params:query {
  idOnly: true
  deleted: true
  ~query: name={{realm}}
  ~full: true
}

headers {
  x-okapi-tenant: {{realm}}
  ~x-okapi-token: 
}

script:pre-request {
  const res = await bru.runRequest("auth/get-keycloak-tenant-token");
}

settings {
  encodeUrl: true
  timeout: 0
}
