meta {
  name: GET specifications fields
  type: http
  seq: 2
}

get {
  url: https://kong-{{folio}}.{{domain}}/specification-storage/specifications/:spec_id/fields
  body: none
  auth: inherit
}

params:path {
  spec_id: a37d01ba-75c7-4a0c-997e-309823f1df3f
}

headers {
  x-okapi-token: {{okapi-token}}
  x-okapi-tenant: {{realm}}
}

script:pre-request {
  var keycloakUrl = `https://keycloak-${bru.getEnvVar('folio')}.${bru.getEnvVar('domain')}/realms/${bru.getEnvVar('realm')}/protocol/openid-connect/token`;
  
  
  // pm.sendRequest({
      url: keycloakUrl,
      method: 'POST',
      header: {
          'content-type': 'application/x-www-form-urlencoded'
      },
      body: {
          mode: 'urlencoded',
          urlencoded: [
              {key: 'grant_type', value: 'client_credentials'},
              {key: 'client_id', value: bru.getEnvVar('tenant_client')},
              {key: 'client_secret', value: bru.getEnvVar('tenant_client_secret')}
          ]
      }
  }, (err, res) => bru.setEnvVar("okapi-token", res.json().access_token));
}

settings {
  encodeUrl: true
}
