meta {
  name: /reading-room/access-log endpoint Copy
  type: http
  seq: 2
}

get {
  url: https://kong-{{folio}}.{{domain}}/reading-room/access-log
  body: none
  auth: inherit
}

params:query {
  ~query: readingRoomName=Reading 1
}

headers {
  x-okapi-token: {{okapi-token}}
  x-okapi-tenant: {{realm}}
}

settings {
  encodeUrl: true
  timeout: 0
}
