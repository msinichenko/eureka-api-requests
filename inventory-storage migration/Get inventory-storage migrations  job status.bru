meta {
  name: Get inventory-storage migrations  job status
  type: http
  seq: 4
}

get {
  url: https://kong-{{folio}}.{{domain}}/inventory-storage/migrations/jobs/:job_id
  body: none
  auth: none
}

params:path {
  job_id: b26d763e-bcb7-4815-a504-9c19286d15a3
}

headers {
  x-okapi-token: {{okapi-token}}
  x-okapi-tenant: {{realm}}
}

script:pre-request {
  var keycloakUrl = `https://keycloak-${bru.getEnvVar('folio')}.${bru.getEnvVar('domain')}/realms/${bru.getEnvVar('realm')}/protocol/openid-connect/token`;
  
  
  // pm.sendRequest({
      url: keycloakUrl,
      method: 'POST',
      header: {
          'content-type': 'application/x-www-form-urlencoded'
      },
      body: {
          mode: 'urlencoded',
          urlencoded: [
              {key: 'grant_type', value: 'client_credentials'},
              {key: 'client_id', value: bru.getEnvVar('tenant_client')},
              {key: 'client_secret', value: bru.getEnvVar('tenant_client_secret')}
          ]
      }
  }, (err, res) => bru.setEnvVar("okapi-token", res.json().access_token));
}

settings {
  encodeUrl: true
}
