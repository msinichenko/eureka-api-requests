meta {
  name: inventory-storage Submit a migration job
  type: http
  seq: 3
}

post {
  url: https://kong-{{folio}}.{{domain}}/inventory-storage/migrations/jobs
  body: json
  auth: none
}

headers {
  x-okapi-token: {{okapi-token}}
  x-okapi-tenant: {{realm}}
}

body:json {
  {
      "migrations": [
          "publicationPeriodMigration"
      ]
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
