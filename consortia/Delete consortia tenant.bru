meta {
  name: Delete consortia tenant
  type: http
  seq: 9
}

delete {
  url: https://kong-{{folio}}.{{domain}}/consortia/:consortia_id/tenants/:tenant_id
  body: json
  auth: none
}

params:query {
  ~query: username =testuser11
  ~limit: 100
}

params:path {
  consortia_id: {{consortia_id}}
  tenant_id: {{member_tenant_id}}
}

headers {
  x-okapi-token: {{okapi-token}}
  x-okapi-tenant: {{realm}}
}

body:json {
  {
    "deleteType": "HARD",
    "deleteOptions": {
      "deleteUsersUserTenants": true,
      "deleteRelatedShadowUsers": true
    }
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
