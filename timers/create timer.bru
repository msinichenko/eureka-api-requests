meta {
  name: create timer
  type: http
  seq: 3
}

get {
  url: https://kong-{{folio}}.{{domain}}/scheduler/timers?limit=500
  body: none
  auth: none
}

params:query {
  limit: 500
  ~query: enabled==false
}

headers {
  x-okapi-tenant: {{realm}}
  x-okapi-token: {{okapi-token}}
}

settings {
  encodeUrl: true
  timeout: 0
}
