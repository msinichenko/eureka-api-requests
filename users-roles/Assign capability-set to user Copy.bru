meta {
  name: Assign capability-set to user Copy
  type: http
  seq: 27
}

get {
  url: https://kong-{{folio}}.{{domain}}/capabilities?query=permission==accounts.cancel.post
  body: json
  auth: none
}

params:query {
  query: permission==accounts.cancel.post
}

headers {
  x-okapi-token: {{okapi-token}}
  x-okapi-tenant: {{realm}}
}

body:json {
  {
  
    "userId": "2b019b1b-9924-4bd4-b49e-54cddc85c777",
    "capabilitySetIds": [
      "836ed9d5-e178-423b-899f-4a998d17e3fd"
    ]
  }
}

script:pre-request {
  const res = await bru.runRequest("auth/get-keycloak-tenant-token");
}settings {
  encodeUrl: true
  timeout: 0
}
