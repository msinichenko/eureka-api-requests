meta {
  name: Delete user
  type: http
  seq: 5
}

delete {
  url: https://kong-{{folio}}.{{domain}}/users-keycloak/users/:user_id
  body: json
  auth: none
}

params:path {
  user_id: 6e9e425e-683d-4937-9301-ecb06c0938b6
}

headers {
  x-okapi-token: {{okapi-token}}
  x-okapi-tenant: {{realm}}
}

script:pre-request {
  const res = await bru.runRequest("auth/get-keycloak-tenant-token");
}settings {
  encodeUrl: true
  timeout: 0
}
