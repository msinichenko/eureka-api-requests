meta {
  name: Create user password
  type: http
  seq: 7
}

post {
  url: https://kong-{{folio}}.{{domain}}/authn/credentials
  body: json
  auth: none
}

headers {
  x-okapi-token: {{okapi-token}}
  x-okapi-tenant: {{realm}}
}

body:json {
  {
      "username": "testuser11",
      "password": "secure_passwordz"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
