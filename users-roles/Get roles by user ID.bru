meta {
  name: Get roles by user ID
  type: http
  seq: 17
}

get {
  url: https://kong-{{folio}}.{{domain}}/roles/users/:user_id
  body: none
  auth: none
}

params:query {
  ~query: username =testuser11
  ~limit: 100
}

params:path {
  user_id: 23f67e44-76ce-4968-9d9a-d01035dc17c1
}

headers {
  x-okapi-token: {{okapi-token}}
  x-okapi-tenant: {{realm}}
}

script:pre-request {
  const res = await bru.runRequest("auth/get-keycloak-tenant-token");
}settings {
  encodeUrl: true
  timeout: 0
}
