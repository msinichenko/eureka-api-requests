meta {
  name: RE-upload instance
  type: http
  seq: 10
}

post {
  url: https://kong-{{folio}}.{{domain}}/search/index/instance-records/reindex/upload
  body: json
  auth: none
}

headers {
  x-okapi-token: {{okapi-token}}
  x-okapi-tenant: {{realm}}
}

body:json {
  {  "indexSettings": {},  "entityTypes": ["instance","subject","contributor","classification","call-number"] }
}

settings {
  encodeUrl: true
  timeout: 0
}
