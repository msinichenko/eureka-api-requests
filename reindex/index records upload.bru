meta {
  name: index records upload
  type: http
  seq: 3
}

post {
  url: https://kong-{{folio}}.{{domain}}/search/index/instance-records/reindex/upload
  body: json
  auth: none
}

headers {
  x-okapi-token: {{okapi-token}}
  x-okapi-tenant: {{realm}}
}

body:json {
  {
    "entityTypes": ["instance", "subject", "contributor", "classification", "call-number"]
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
