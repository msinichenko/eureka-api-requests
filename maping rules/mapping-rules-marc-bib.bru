  test("Response contains the key 'LDR' with an array as its value", function () {
      const responseData = res.getBody();
      expect(responseData).to.have.property('LDR').that.is.an('array');
  });
  test("LDR contains specific data", function () {
      const responseData = res.getBody();
      
     expect(responseData.LDR.length).to.be.greaterThan(0); // Replace 'expectedValue' with the actual value you want to check.
  });
  
}

settings {
  encodeUrl: true
  timeout: 0
}
