  // });
  
  
  const responseData = res.getBody();
  
  test("Each entity must have the required fields: target, subfield, and description", function () {
      Object.keys(responseData).forEach(key => {
          responseData[key].forEach(item => {
              if (item.entity) {
                  item.entity.forEach(entity => {
                      expect(entity).to.have.property('target').that.is.a('string');
                      expect(entity).to.have.property('subfield').that.is.an('array');
                      expect(entity).to.have.property('description').that.is.a('string');
                  });
              }
              if (item.rules) {
                  item.rules.forEach(rule => {
                      expect(rule).to.have.property('conditions').that.is.an('array');
                  });
              }
          });
      });
  });
  
  
  // // pm.test("Validate that rules and conditions are in the expected format", function () {
