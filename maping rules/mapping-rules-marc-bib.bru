meta {
  name: mapping-rules/marc-bib
  type: http
  seq: 1
}

get {
  url: https://kong-{{folio}}.{{domain}}/mapping-rules/marc-bib
  body: none
  auth: inherit
}

headers {
  x-okapi-token: {{okapi-token}}
  x-okapi-tenant: {{realm}}
}

script:post-response {
  test("Response status code is 200", function () {
      expect(res.getStatus()).to.equal(200);
  });
  
  
